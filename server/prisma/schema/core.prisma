// --- CORE WIKI IDENTITY: SOURCE ---

model Source {
    id               String  @id @default(cuid())
    url              String? @db.VarChar(2560) // External URL
    path             String? // Local Identity Slug (e.g., "physics")
    materializedPath String? @unique // Full Routing Path (e.g., "science/physics")
    depth            Int     @default(0)
    title            String? @db.VarChar(255)
    description      String? @db.Text

    type             String    @default("WEB") // WEB, BOOK, WIKI_PAGE, etc.
    reliabilityScore Float?    @default(1.0)
    isPublished      Boolean   @default(false)
    publishedAt      DateTime?
    status           String?   @default("NEW")

    // Ownership
    userId String
    user   User   @relation(fields: [userId], references: [id])

    // Hierarchy: Stable tree structure based on Identity/Source
    parentId String?
    parent   Source?  @relation("SourceHierarchy", fields: [parentId], references: [id])
    children Source[] @relation("SourceHierarchy")

    // Content: Multiple possible versions of text for this identity
    texts Text[] @relation("SourceTexts")

    // Semantic Graph: Connections between identities
    outboundRelations Relation[] @relation("SourceOutbound")
    inboundRelations  Relation[] @relation("SourceInbound")

    // Metadata (Favicon, OG data, site info)
    metadata Json?

    tags        Tag[]
    attachments Attachment[]
    feeds       Feed[]       @relation("FeedSources")
    reports     Report[]

    existent  Boolean? @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([url])
    @@unique([parentId, path])
    @@index([existent])
    @@index([parentId])
    @@index([materializedPath])
}

// --- CORE WIKI CONTENT: TEXT ---

model Text {
    id       String  @id @default(cuid())
    content  String  @db.Text
    language String? @default("et")

    isPublished Boolean  @default(false)
    existent    Boolean? @default(true)

    // Identity: Each text block belongs to exactly one Source identity
    originSourceId String
    originSource   Source @relation("SourceTexts", fields: [originSourceId], references: [id], onDelete: Cascade)

    // Ownership
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Enrichment & AI
    chunks      Chunk[]
    attachments Attachment[]
    tags        Tag[]
    metrics     AnalysisMetric[]

    // Relationship to Reports (if this text is part of an analysis)
    reports Report[] @relation("ReportContent")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([originSourceId])
}

// --- SEMANTIC LINKING: RELATION ---

model Relation {
    id   String @id @default(cuid())
    role String @default("REFERENCE") // ORIGIN, CITATION, FEATURE, SPECIMEN, LINK, SUMMARY

    // Graph Edge: Connects two identities
    fromSourceId String
    fromSource   Source @relation("SourceOutbound", fields: [fromSourceId], references: [id], onDelete: Cascade)

    toSourceId String
    toSource   Source @relation("SourceInbound", fields: [toSourceId], references: [id], onDelete: Cascade)

    // Context: Offset [start, end], specific markup context, etc.
    metadata Json?

    createdAt DateTime @default(now())

    @@index([fromSourceId])
    @@index([toSourceId])
}

model Chunk {
    id     String @id @default(cuid())
    textId String
    text   Text   @relation(fields: [textId], references: [id], onDelete: Cascade)

    content        String @db.Text
    selectionStart Int?
    selectionEnd   Int?

    aiModelId String
    aiModel   AIModel @relation(fields: [aiModelId], references: [id])

    bge_base_en_v1_5       Unsupported("vector(768)")?
    all_minilm_l6_v2       Unsupported("vector(384)")?
    text_embedding_3_small Unsupported("vector(1536)")?
    text_embedding_004     Unsupported("vector(768)")?

    existent  Boolean? @default(true)
    createdAt DateTime @default(now())

    @@index([textId])
}

model AIModel {
    id       String  @id @default(cuid())
    name     String  @unique
    provider String
    version  String?
    type     String  @default("GENERATIVE")

    reports        Report[]
    chunks         Chunk[]
    promptVersions PromptVersion[]

    existent  Boolean? @default(true)
    createdAt DateTime @default(now())
}

model Feed {
    id            String    @id @default(cuid())
    url           String    @unique
    name          String
    pollingPeriod Int       @default(60)
    lastPolledAt  DateTime?

    userId String
    user   User   @relation(fields: [userId], references: [id])

    sources Source[] @relation("FeedSources")

    defaultTagName  String?
    defaultTagValue String?
    aiPrompt        String?  @db.Text  // AI task to run on every new item

    enabled   Boolean  @default(true)
    existent  Boolean? @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Attachment {
    id       String @id @default(cuid())
    filename String
    mimetype String
    url      String
    size     Int

    sourceId String?
    source   Source? @relation(fields: [sourceId], references: [id])
    textId   String?
    text     Text?   @relation(fields: [textId], references: [id])

    existent  Boolean? @default(true)
    createdAt DateTime @default(now())
}

model Tag {
    id      String   @id @default(cuid())
    name    String
    value   String?
    reports Report[]
    texts   Text[]
    sources Source[]

    isPublished Boolean @default(false)
    permalink   String? @unique

    existent Boolean? @default(true)

    @@unique([name, value])
    @@index([name])
    @@index([value])
}
