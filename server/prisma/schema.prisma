// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["postgresqlExtensions"]
}

datasource db {
    provider   = "postgresql"
    extensions = [vector]
}

// --- USER & AUTHENTICATION ---

model User {
    id                String             @id @default(cuid())
    email             String             @unique
    name              String?
    googleId          String?            @unique
    consents          UserConsent[]
    sessions          Session[]
    topics            Topic[]
    texts             Text[]
    roles             UserRole[]
    moderationReports ModerationReport[]
    notifications     Notification[]
    quotas            UserQuota[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    feedbacks      Feedback[]
    threadMessages ThreadMessage[]
}

model Role {
    id          String     @id @default(cuid())
    name        String     @unique // "ADMIN", "MODERATOR", "USER"
    description String?    @db.Text
    users       UserRole[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

model UserRole {
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    roleId String
    role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

    existent DateTime? @default(now())

    @@id([userId, roleId])
}

model UserQuota {
    id      String   @id @default(cuid())
    userId  String
    user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    type    String // e.g., "ANALYSIS_PER_DAY", "TOKEN_LIMIT"
    limit   Int
    usage   Int      @default(0)
    resetAt DateTime

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    @@unique([userId, type])
}

model Session {
    id        String        @id @default(cuid())
    userId    String
    user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    token     String        @unique
    expiresAt DateTime
    consents  UserConsent[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

model UserConsent {
    id      String             @id @default(cuid())
    userId  String
    user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    termsId String
    terms   TermsAndConditions @relation(fields: [termsId], references: [id])

    // Granular consent types
    consentType String @default("GENERAL") // "GENERAL", "AI_PROCESSING", "THIRD_PARTY_DISCLOSURE", "PUBLISHING", "TOPIC_CREATION", "TEXT_CREATION", "COPYRIGHT_ACK"

    consentDate      DateTime @default(now())
    consentSessionId String?
    consentSession   Session? @relation(fields: [consentSessionId], references: [id])

    // Linked to specific activity
    analyzeRequestId String?
    analyzeRequest   AnalyzeRequest? @relation(fields: [analyzeRequestId], references: [id])
    topicId          String?
    topic            Topic?          @relation(fields: [topicId], references: [id])
    textId           String?
    text             Text?           @relation("TextConsent", fields: [textId], references: [id])

    existent DateTime? @default(now())

    @@index([userId])
    @@index([termsId])
}

model TermsAndConditions {
    id       String        @id @default(cuid())
    version  String        @unique
    content  String        @db.Text
    isActive Boolean       @default(true)
    consents UserConsent[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

// --- CORE TOPIC & TEXT ---

model Topic {
    id     String @id @default(cuid())
    title  String @db.VarChar(255)
    userId String
    user   User   @relation(fields: [userId], references: [id])

    language String? @default("et") // "et", "en", etc.

    // Topic has one primary text
    primaryTextId String @unique
    primaryText   Text   @relation("PrimaryTopic", fields: [primaryTextId], references: [id])

    // Topic can have zero to many related context texts for RAG
    contextTexts TopicContext[]

    sources         Source[]
    analyzeRequests AnalyzeRequest[]
    consents        UserConsent[]
    attachments     Attachment[]
    tags            Tag[]

    // Storage preference
    removeTextAfterReport Boolean @default(false)

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

model Text {
    id       String  @id @default(cuid())
    content  String  @db.Text
    userId   String
    user     User    @relation(fields: [userId], references: [id])
    language String? @default("et")

    // Relationships to Topic (as Primary or Context)
    topicAsPrimary  Topic?         @relation("PrimaryTopic")
    topicsAsContext TopicContext[]

    // Relationship to Report (if this text is a response)
    report Report? @relation("ReportContent")

    // Relationship to TextFeature (if this text is a feature description)
    featureDesc TextFeature? @relation("FeatureDescription")

    // Relationship to Claim (if this text is an explanation)
    claimExplanation Claim? @relation("ClaimExplanation")

    // Relationship to AnalysisMetric (if this text is a metric justification)
    metricJustification AnalysisMetric? @relation("MetricJustification")

    consents UserConsent[] @relation("TextConsent")

    // Social Engagement
    feedbacks      Feedback[]
    threadMessages ThreadMessage[]

    // Textual Analysis
    featureInstances FeatureInstance[]

    // RAG Chunks
    chunks Chunk[]

    // Moderation
    moderationReports ModerationReport[]

    tags Tag[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

model Chunk {
    id     String @id @default(cuid())
    textId String
    text   Text   @relation(fields: [textId], references: [id], onDelete: Cascade)

    content        String @db.Text
    selectionStart Int?
    selectionEnd   Int?

    // The embedding model used
    aiModelId String
    aiModel   AIModel @relation(fields: [aiModelId], references: [id])

    embedding Unsupported("vector(1536)")?

    claims ClaimEvidence[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())

    @@index([textId])
    @@index([aiModelId])
}

model TopicContext {
    topicId String
    topic   Topic  @relation(fields: [topicId], references: [id])
    textId  String
    text    Text   @relation(fields: [textId], references: [id])

    existent DateTime? @default(now())

    @@id([topicId, textId])
}

model Source {
    id          String  @id @default(cuid())
    url         String? @db.VarChar(2560)
    title       String? @db.VarChar(255)
    description String? @db.Text

    type             String @default("WEB") // WEB, BOOK, DOCUMENT, SOCIAL_MEDIA
    reliabilityScore Float? @default(1.0) // 0.0 to 1.0 (internal meta-data)

    topicId     String
    topic       Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
    attachments Attachment[]
    tags        Tag[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

model Attachment {
    id       String @id @default(cuid())
    filename String
    mimetype String
    url      String // Storage URL (S3/local)
    size     Int

    topicId  String?
    topic    Topic?  @relation(fields: [topicId], references: [id])
    sourceId String?
    source   Source? @relation(fields: [sourceId], references: [id])

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

// --- ANALYSIS & REPORTS ---

model AIModel {
    id       String  @id @default(cuid())
    name     String  @unique // e.g., "gpt-4o", "text-embedding-3-small"
    provider String // e.g., "OpenAI", "Google"
    version  String?
    type     String  @default("GENERATIVE") // "GENERATIVE", "EMBEDDING"

    reports        Report[]
    chunks         Chunk[]
    promptVersions PromptVersion[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

model PromptTemplate {
    id          String          @id @default(cuid())
    name        String          @unique // e.g., "RHETORIC_ANALYSIS_V1"
    description String?
    versions    PromptVersion[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

model PromptVersion {
    id         String         @id @default(cuid())
    templateId String
    template   PromptTemplate @relation(fields: [templateId], references: [id])
    version    Int
    content    String         @db.Text // The actual system instructions

    // Optimized for a specific model
    optimizedForModelId String?
    optimizedForModel   AIModel? @relation(fields: [optimizedForModelId], references: [id])

    requests AnalyzeRequest[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

model AnalyzeRequest {
    id      String @id @default(cuid())
    topicId String
    topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

    // Tracking the prompt used
    promptVersionId String?
    promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id])

    promptSettings Json // Additional dynamic parameters

    status String  @default("PENDING") // PENDING, FETCHING, CHUNKING, EMBEDDING, PROCESSING, COMPLETED, FAILED
    report Report?

    consents UserConsent[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

model Report {
    id        String         @id @default(cuid())
    requestId String         @unique
    request   AnalyzeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

    textId String @unique
    text   Text   @relation("ReportContent", fields: [textId], references: [id], onDelete: Cascade)

    aiModelId         String
    aiModel           AIModel @relation(fields: [aiModelId], references: [id])
    isAiGenerated     Boolean @default(true)
    transparencyLabel String?

    claims  Claim[]
    metrics AnalysisMetric[]

    resultJson  Json // Raw structured data from agent
    isPublished Boolean @default(false)
    permalink   String? @unique
    tags        Tag[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

model Claim {
    id       String @id @default(cuid())
    reportId String
    report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

    content String @db.Text

    // Refutation or explanation is its own Text entity
    explanationTextId String? @unique
    explanationText   Text?   @relation("ClaimExplanation", fields: [explanationTextId], references: [id])

    truthValue     String? // e.g., "TRUE", "FALSE", "MISLEADING", "UNVERIFIED"
    certaintyScore Float? // 0.0 to 1.0

    evidence ClaimEvidence[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

model ClaimEvidence {
    claimId String
    claim   Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)
    chunkId String
    chunk   Chunk  @relation(fields: [chunkId], references: [id], onDelete: Cascade)

    existent DateTime? @default(now())

    @@id([claimId, chunkId])
}

// --- TEXTUAL FEATURES & TAXONOMY ---

model Taxonomy {
    id          String  @id @default(cuid())
    name        String  @unique
    description String? @db.Text

    parentId String?
    parent   Taxonomy?  @relation("TaxonomyHierarchy", fields: [parentId], references: [id])
    children Taxonomy[] @relation("TaxonomyHierarchy")

    features TextFeature[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

model TextFeature {
    id   String @id @default(cuid())
    name String @unique

    textId String @unique
    text   Text   @relation("FeatureDescription", fields: [textId], references: [id], onDelete: Cascade)

    taxonomyId String
    taxonomy   Taxonomy @relation(fields: [taxonomyId], references: [id])

    instances FeatureInstance[]

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

model FeatureInstance {
    id          String      @id @default(cuid())
    featureId   String
    feature     TextFeature @relation(fields: [featureId], references: [id])
    textId      String
    text        Text        @relation(fields: [textId], references: [id], onDelete: Cascade)
    startOffset Int
    endOffset   Int
    metadata    Json?

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

// --- SOCIAL & FEEDBACK ---

model Feedback {
    id      String  @id @default(cuid())
    userId  String
    user    User    @relation(fields: [userId], references: [id])
    textId  String
    text    Text    @relation(fields: [textId], references: [id], onDelete: Cascade)
    rating  Int
    comment String? @db.Text

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

model ThreadMessage {
    id       String          @id @default(cuid())
    userId   String
    user     User            @relation(fields: [userId], references: [id])
    textId   String
    text     Text            @relation(fields: [textId], references: [id], onDelete: Cascade)
    content  String          @db.Text
    parentId String?
    parent   ThreadMessage?  @relation("ThreadReplies", fields: [parentId], references: [id])
    replies  ThreadMessage[] @relation("ThreadReplies")

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

// --- COMPLIANCE & MODERATION ---

model Notification {
    id      String  @id @default(cuid())
    userId  String
    user    User    @relation(fields: [userId], references: [id])
    title   String
    content String  @db.Text
    isRead  Boolean @default(false)
    link    String?

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}

model ModerationReport {
    id          String  @id @default(cuid())
    reporterId  String?
    reporter    User?   @relation(fields: [reporterId], references: [id])
    textId      String
    text        Text    @relation(fields: [textId], references: [id], onDelete: Cascade)
    reason      String
    status      String  @default("OPEN") // OPEN, REVIEWING, RESOLVED, DISMISSED
    actionTaken String?

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

model AuditLog {
    id         String   @id @default(cuid())
    entityType String
    entityId   String
    action     String
    userId     String?
    metadata   Json?
    timestamp  DateTime @default(now())
}

// --- CATEGORIZATION ---

model Tag {
    id      String   @id @default(cuid())
    name    String   @unique
    topics  Topic[]
    sources Source[]
    reports Report[]
    texts   Text[]

    existent DateTime? @default(now())
}

model AnalysisMetric {
    id       String @id @default(cuid())
    reportId String
    report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

    name  String // e.g., "Ethics Index", "Bias Score", "Sentiment"
    value Float // e.g., 0.85

    // Justification is its own Text entity
    textId String? @unique
    text   Text?   @relation("MetricJustification", fields: [textId], references: [id])

    existent  DateTime? @default(now())
    createdAt DateTime  @default(now())
}
