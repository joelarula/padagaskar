generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../ERD.svg"
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model AIModel {
  id            String          @id
  name          String          @unique
  provider      String
  version       String?
  type          String          @default("GENERATIVE")
  existent      DateTime?       @default(now())
  createdAt     DateTime        @default(now())
  Chunk         Chunk[]
  PromptVersion PromptVersion[]
  Report        Report[]
}

model AnalysisMetric {
  id            String    @id
  reportId      String?
  name          String
  value         Float
  existent      DateTime? @default(now())
  createdAt     DateTime  @default(now())
  justification String
  specimenId    String?
  Report        Report?   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  Specimen      Specimen? @relation(fields: [specimenId], references: [id], onDelete: Cascade)
}

model AnalyzeRequest {
  id              String         @id
  topicId         String
  promptVersionId String?
  status          String         @default("PENDING")
  existent        DateTime?      @default(now())
  createdAt       DateTime       @default(now())
  PromptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id])
  Topic           Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  Report          Report?
}

model Attachment {
  id        String    @id
  filename  String
  mimetype  String
  url       String
  size      Int
  topicId   String?
  sourceId  String?
  existent  DateTime? @default(now())
  createdAt DateTime  @default(now())
  Source    Source?   @relation(fields: [sourceId], references: [id])
  Topic     Topic?    @relation(fields: [topicId], references: [id])
}

model AuditLog {
  id         String   @id
  entityType String
  entityId   String
  action     String
  userId     String?
  metadata   Json?
  timestamp  DateTime @default(now())
}

model Category {
  id             String        @id
  name           String        @unique
  description    String?
  parentId       String?
  existent       DateTime?     @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  Category       Category?     @relation("CategoryToCategory", fields: [parentId], references: [id])
  other_Category Category[]    @relation("CategoryToCategory")
  TextFeature    TextFeature[]
}

model Chunk {
  id                     String                 @id
  textId                 String
  content                String
  selectionStart         Int?
  selectionEnd           Int?
  aiModelId              String
  existent               DateTime?              @default(now())
  createdAt              DateTime               @default(now())
  all_minilm_l6_v2       Unsupported("vector")?
  bge_base_en_v1_5       Unsupported("vector")?
  text_embedding_3_small Unsupported("vector")?
  AIModel                AIModel                @relation(fields: [aiModelId], references: [id])
  Text                   Text                   @relation(fields: [textId], references: [id], onDelete: Cascade)

  @@index([aiModelId])
  @@index([textId])
}

model PromptTemplate {
  id            String          @id
  name          String          @unique
  description   String?
  existent      DateTime?       @default(now())
  createdAt     DateTime        @default(now())
  PromptVersion PromptVersion[]
}

model PromptVersion {
  id                  String           @id
  templateId          String
  version             Int
  content             String
  optimizedForModelId String?
  existent            DateTime?        @default(now())
  createdAt           DateTime         @default(now())
  AnalyzeRequest      AnalyzeRequest[]
  AIModel             AIModel?         @relation(fields: [optimizedForModelId], references: [id])
  PromptTemplate      PromptTemplate   @relation(fields: [templateId], references: [id])
}

model Report {
  id                String           @id
  requestId         String           @unique
  textId            String           @unique
  aiModelId         String
  isAiGenerated     Boolean          @default(true)
  transparencyLabel String?
  resultJson        Json
  isPublished       Boolean          @default(false)
  permalink         String?          @unique
  existent          DateTime?        @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  AnalysisMetric    AnalysisMetric[]
  AIModel           AIModel          @relation(fields: [aiModelId], references: [id])
  AnalyzeRequest    AnalyzeRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  Text              Text             @relation(fields: [textId], references: [id], onDelete: Cascade)
  Tag               Tag[]
}

model Role {
  id          String     @id
  name        String     @unique
  description String?
  existent    DateTime?  @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  UserRole    UserRole[]
}

model Session {
  id          String        @id
  userId      String
  token       String        @unique
  expiresAt   DateTime
  existent    DateTime?     @default(now())
  createdAt   DateTime      @default(now())
  User        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  UserConsent UserConsent[]
}

model Source {
  id               String       @id
  url              String?      @db.VarChar(2560)
  title            String?      @db.VarChar(255)
  description      String?
  type             String       @default("WEB")
  reliabilityScore Float?       @default(1.0)
  existent         DateTime?    @default(now())
  createdAt        DateTime     @default(now())
  textId           String?
  Attachment       Attachment[]
  Text             Text?        @relation(fields: [textId], references: [id], onDelete: Cascade)
}

model Specimen {
  id                                    String           @id
  featureId                             String
  textId                                String
  startOffset                           Int?
  endOffset                             Int?
  explanationTextId                     String?          @unique
  existent                              DateTime?        @default(now())
  createdAt                             DateTime         @default(now())
  AnalysisMetric                        AnalysisMetric[]
  Text_Specimen_explanationTextIdToText Text?            @relation("Specimen_explanationTextIdToText", fields: [explanationTextId], references: [id])
  TextFeature                           TextFeature      @relation(fields: [featureId], references: [id])
  Text_Specimen_textIdToText            Text             @relation("Specimen_textIdToText", fields: [textId], references: [id], onDelete: Cascade)
}

model Tag {
  id          String    @id
  name        String    @unique
  existent    DateTime? @default(now())
  isPublished Boolean   @default(false)
  permalink   String?   @unique
  Report      Report[]
  Text        Text[]
  Topic       Topic[]
}

model TermsAndConditions {
  id          String        @id
  version     String        @unique
  content     String
  isActive    Boolean       @default(true)
  existent    DateTime?     @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  UserConsent UserConsent[]
}

model Text {
  id                                        String       @id
  content                                   String
  userId                                    String
  language                                  String?      @default("et")
  existent                                  DateTime?    @default(now())
  createdAt                                 DateTime     @default(now())
  updatedAt                                 DateTime
  Chunk                                     Chunk[]
  Report                                    Report?
  Source                                    Source[]
  Specimen_Specimen_explanationTextIdToText Specimen?    @relation("Specimen_explanationTextIdToText")
  Specimen_Specimen_textIdToText            Specimen[]   @relation("Specimen_textIdToText")
  User                                      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  TextFeature                               TextFeature?
  Tag                                       Tag[]
  Topic                                     Topic[]      @relation("TopicTexts")
}

model TextFeature {
  id         String     @id
  name       String     @unique
  textId     String     @unique
  existent   DateTime?  @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime
  categoryId String
  Specimen   Specimen[]
  Category   Category   @relation(fields: [categoryId], references: [id])
  Text       Text       @relation(fields: [textId], references: [id], onDelete: Cascade)
}

model Topic {
  id             String           @id
  title          String           @db.VarChar(255)
  userId         String
  language       String?          @default("et")
  existent       DateTime?        @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  description    String?
  isPublished    Boolean          @default(false)
  permalink      String?          @unique
  summary        String?
  AnalyzeRequest AnalyzeRequest[]
  Attachment     Attachment[]
  User           User             @relation(fields: [userId], references: [id])
  Tag            Tag[]
  Text           Text[]           @relation("TopicTexts")
}

model User {
  id          String        @id
  email       String        @unique
  name        String?
  googleId    String?       @unique
  existent    DateTime?     @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  Session     Session[]
  Text        Text[]
  Topic       Topic[]
  UserConsent UserConsent[]
  UserQuota   UserQuota[]
  UserRole    UserRole[]
}

model UserConsent {
  id                 String             @id
  userId             String
  termsId            String
  consentType        String             @default("GENERAL")
  consentDate        DateTime           @default(now())
  existent           DateTime?          @default(now())
  entityId           String?
  entityType         String?
  sessionId          String?
  Session            Session?           @relation(fields: [sessionId], references: [id])
  TermsAndConditions TermsAndConditions @relation(fields: [termsId], references: [id])
  User               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityId, entityType])
  @@index([termsId])
  @@index([userId])
}

model UserQuota {
  id        String    @id
  userId    String
  type      String
  limit     Int
  usage     Int       @default(0)
  resetAt   DateTime
  existent  DateTime? @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model UserRole {
  userId   String
  roleId   String
  existent DateTime? @default(now())
  Role     Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  User     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}
