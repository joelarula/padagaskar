{
  "name": "Padagaskar Dev Container",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },
  "forwardPorts": [3000, 5173, 5432, 5555],
  "portsAttributes": {
    "3000": { "label": "Server (GraphQL)" },
    "5173": { "label": "Frontend (Vite)" },
    "5432": { "label": "PostgreSQL" },
    "5555": { "label": "Prisma Studio" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "Prisma.prisma",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",

        "GraphQL.vscode-graphql",
        "GraphQL.vscode-graphql-syntax"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "git config --global --add safe.directory /workspace && npm run install:all && cd server && npx prisma generate",
  "remoteEnv": {
    "DATABASE_URL": "postgresql://user:password@db:5432/padagaskar"
  }
}
